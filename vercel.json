{
  "redirects": [
    { "source": "/work", "destination": "/projects", "permanent": true },
    { "source": "/work/:slug", "destination": "/projects/:slug", "permanent": true },
    { "source": "/case-studies", "destination": "/projects", "permanent": true },
    { "source": "/seo-websites", "destination": "/seo-friendly-websites", "permanent": true },
    { "source": "/custom-web-apps", "destination": "/custom-web-applications", "permanent": true }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
