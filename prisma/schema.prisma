generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadSource {
  CONTACT
  DISCOVERY_CALL
  PROJECT_INQUIRY
}

model LeadSubmission {
  id          String     @id @default(cuid())
  source      LeadSource
  firstName   String
  lastName    String
  email       String
  company     String?
  service     String?
  budget      String?
  message     String?
  day         String?
  time        String?
  projectSummary String?
  inspiration String?
  startDate   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([source, createdAt])
  @@index([email])
}
